# OpenClaw 環境變數設定範例
#
# 使用方式：
# 1) 複製此文件為 `.env`（本地開發）或 `~/.openclaw/.env`（守護進程）
# 2) 僅填入你使用的服務
# 3) 不要將真實密鑰提交到 Git
#
# 環境變數優先順序（高 → 低）：
# 進程環境變數 > ./.env > ~/.openclaw/.env > openclaw.json 的 env 區塊
# 注意：非空的進程環境變數不會被覆蓋
#
# ⚠️  跨平台注意事項：
# - OPENAI_BASE_URL：依作業系統選擇對應行（見下方說明）
# - Windows/macOS 使用 host.docker.internal
# - Linux/Raspberry Pi 使用 172.17.0.1 或主機 IP

# ─────────────────────────────────────────────────────────────────────
# Gateway 認證 + 路徑
# ─────────────────────────────────────────────────────────────────────

# Gateway 認證令牌（若 gateway 綁定到非本地地址時推薦）
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
# 範例生成器：openssl rand -hex 32

# 可選：使用密碼代替令牌（二選一）
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# 可選：路徑覆蓋（默認值如下）
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# 可選：從登錄殼層配置導入缺失的密鑰
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# ─────────────────────────────────────────────────────────────────────
# 模型提供者 API 密鑰（至少設置一個）
# ─────────────────────────────────────────────────────────────────────

# OpenAI（ChatGPT）
OPENAI_API_KEY=sk-xxx...

# ── 連接到 openSOUL 本地 API（選擇符合你平台的那一行）──────────
# openSOUL 透過 OpenAI 兼容接口與 OpenClaw 溝通
#
# ⚠️  注意：不能使用 127.0.0.1！
# OpenClaw 跑在 Docker 容器內，127.0.0.1 代表容器自己，
# 不是你的主機。Soul API 跑在主機上，需要用以下方式存取：
LLM_PROVIDER=custom_openai
MODEL=aria

# Windows / macOS（Docker Desktop 自動提供此 DNS 指向主機）
OPENAI_BASE_URL=http://host.docker.internal:6781/v1

# Linux / Raspberry Pi（Docker bridge 網路的預設閘道，即主機）
# OPENAI_BASE_URL=http://172.17.0.1:6781/v1

# 任何平台（用主機在區網的 IP，最穩定）
# OPENAI_BASE_URL=http://YOUR_HOST_IP:6781/v1
# 查詢方式：
#   Windows  → ipconfig
#   Linux/Pi → hostname -I | awk '{print $1}'
#   macOS    → ipconfig getifaddr en0

# Anthropic（Claude）
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=...

# OpenRouter（多模型聚合）
# OPENROUTER_API_KEY=sk-or-...

# 多個密鑰支持
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...

# 其他提供者
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...

# ─────────────────────────────────────────────────────────────────────
# 通訊頻道（僅設置你啟用的）
# ─────────────────────────────────────────────────────────────────────

# Telegram 機器人
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOW_FROM=114514  # 允許的 User ID，多個用逗號分隔

# Discord
# DISCORD_BOT_TOKEN=your-discord-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Mattermost
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com

# Zalo
# ZALO_BOT_TOKEN=...

# Twitch
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# ─────────────────────────────────────────────────────────────────────
# 工具 + 語音/媒體（可選）
# ─────────────────────────────────────────────────────────────────────

# 搜索引擎
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...

# Web 爬蟲
# FIRECRAWL_API_KEY=...

# 語音合成
# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # ElevenLabs 的別名
# DEEPGRAM_API_KEY=...

# ─────────────────────────────────────────────────────────────────────
# OpenClaw Docker 配置
# ─────────────────────────────────────────────────────────────────────

# 本地配置目錄
OPENCLAW_CONFIG_DIR=~/.openclaw

# 工作區目錄
OPENCLAW_WORKSPACE_DIR=./workspace

# Gateway 和 Bridge 端口
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Gateway 綁定方式（loopback / lan / 0.0.0.0）
OPENCLAW_GATEWAY_BIND=loopback

# Docker 鏡像名稱
OPENCLAW_IMAGE=openclaw:latest

# 可選：額外的 Docker 掛載
# OPENCLAW_EXTRA_MOUNTS=

# 可選：Home 卷名稱
# OPENCLAW_HOME_VOLUME=

# 可選：Docker 中安裝的 APT 包
# OPENCLAW_DOCKER_APT_PACKAGES=

# 可選：沙箱模式
# OPENCLAW_SANDBOX=1

# Docker 套接字路徑（依平台選擇）
# Linux / Raspberry Pi
# OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
# macOS（Docker Desktop）
# OPENCLAW_DOCKER_SOCKET=/var/run/docker.sock
# Windows（Docker Desktop WSL2 模式）
# OPENCLAW_DOCKER_SOCKET=//var/run/docker.sock

# Docker 容器內的 GID
# DOCKER_GID=

# 可選：自動安裝 Docker CLI
# OPENCLAW_INSTALL_DOCKER_CLI=1

# 可選：允許不安全的私有 WebSocket
# OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1
