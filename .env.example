# ═══════════════════════════════════════════════════════════════════════
# openSOUL 環境變數設定範例
#
# 將此文件複製為 .env，然後填入您的實際密鑰和設定
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── LLM 提供者 ──────────────────────────────────────────────────────
# 可選 "anthropic" 或 "openrouter"
SOUL_LLM_PROVIDER=openrouter

# Anthropic API 金鑰（若使用 SOUL_LLM_PROVIDER=anthropic）
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── OpenRouter（當 SOUL_LLM_PROVIDER=openrouter 時使用）──────────
# 取得金鑰：https://openrouter.ai/keys
# 模型格式範例：
#   - anthropic/claude-3.5-sonnet
#   - openai/gpt-4o
#   - google/gemini-2.0-flash-exp:free
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=OpenSoul

# OpenAI API 金鑰（用於 text-embedding-3-small）
OPENAI_API_KEY=your-openai-api-key-here

# ── FalkorDB 圖譜數據庫 ──────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
# 留空表示無密碼，若有密碼請填入
FALKORDB_PASSWORD=

# ── openSOUL 核心設定 ────────────────────────────────────────────
# 記憶文件和工作區路徑
SOUL_WORKSPACE_PATH=./workspace

# 主要 LLM 模型（建議與上方 LLM 提供者一致）
SOUL_LLM_MODEL=google/gemini-2-flash-preview

# LLM 溫度（0.0-1.0，影響回應的隨機性）
SOUL_LLM_TEMPERATURE=0.3

# 嵌入模型和維度
SOUL_EMBEDDING_MODEL=google/gemini-embedding-001
SOUL_EMBEDDING_DIM=3072

# ── 記憶圖譜名稱 ─────────────────────────────────────────────────
# 三層記憶對應的 FalkorDB 圖名稱
SOUL_SEMANTIC_GRAPH=soul_semantic
SOUL_EPISODIC_GRAPH=soul_episodic
SOUL_PROCEDURAL_GRAPH=soul_procedural

# ── 記憶邊權重參數 ───────────────────────────────────────────────
# 影響記憶檢索的相關性評分計算
SOUL_WEIGHT_ALPHA=0.3      # 近期性權重
SOUL_WEIGHT_BETA=0.4       # 頻率權重
SOUL_WEIGHT_GAMMA=0.3      # 顯著性權重
SOUL_DECAY_LAMBDA=0.01     # 遺忘衰減率（每小時）
SOUL_PRUNE_THRESHOLD=0.05  # 邊緣刪除閾值

# ── 行為驗證（Judge Agent）────────────────────────────────────────
SOUL_VERIFY_MAX_RETRIES=3
SOUL_VERIFY_THRESHOLD=0.6  # 基底核驗證通過分數（0-1）

# ── 夢境引擎 ──────────────────────────────────────────────────────
# 用於定時反思和記憶回放
SOUL_DREAM_IDLE_MINUTES=120         # 閒置幾分鐘後觸發夢境
SOUL_DREAM_CRON=0 3 * * *           # Cron 表達式，每日凌晨 3 點
SOUL_DREAM_REPLAY_DA_THRESHOLD=0.3  # 觸發重播的最低多巴胺閾值

# ── FastAPI 服務設定 ──────────────────────────────────────────────
SOUL_API_HOST=0.0.0.0
SOUL_API_PORT=8001
SOUL_API_RELOAD=true

# ── Gmail 郵件集成（OAuth2）───────────────────────────────────
# Gmail 帳號地址
GMAIL_ADDRESS=your-email@gmail.com

# OAuth2 認證文件路徑（自動生成）
# 需將 Google Cloud Console 下載的 credentials.json 放在此路徑
# GMAIL_CREDENTIALS_PATH=./workspace/credentials.json

# OAuth2 令牌文件（首次授權後自動生成）
# GMAIL_TOKEN_PATH=./workspace/token.json

# 郵件檢查間隔（分鐘）
GMAIL_CHECK_INTERVAL_MINUTES=5

# ── OpenClaw 技能庫路徑 ───────────────────────────────────────────
OPENCLAW_SKILLS_PATH=~/.openclaw/skills
