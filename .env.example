# ═══════════════════════════════════════════════════════════════════════
# openSOUL 環境變數設定範例
#
# 將此文件複製為 .env，然後填入您的實際密鑰和設定
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════
# 📌 LLM 和 Embedding 配置 - 三種快速方案
# ═══════════════════════════════════════════════════════════════════════

# 🟢 快速方案 A：使用 OpenRouter（推薦，支持多個 LLM + Embedding）
# ─────────────────────────────────────────────────────────────────────
SOUL_LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=OpenSoul

# OpenRouter LLM 模型選擇（任選一個，推薦 claude-3.5-sonnet）
SOUL_LLM_MODEL=anthropic/claude-3.5-sonnet
# 其他優質選項：
#   - openai/gpt-4o              （最強推理能力）
#   - google/gemini-2-flash      （最快速度）
#   - google/gemini-2.0-flash-exp:free （完全免費）

# OpenRouter Embedding 模型
SOUL_EMBEDDING_PROVIDER=openrouter
SOUL_EMBEDDING_MODEL=openai/text-embedding-3-small
SOUL_EMBEDDING_DIM=1536

# 👉 如果選擇此方案，請跳過下方「方案 B」和「方案 C」


# 🔵 快速方案 B：使用 Anthropic Claude（僅限 Claude 模型）
# ─────────────────────────────────────────────────────────────────────
# 若使用此方案，取消以下行的註釋，並註釋掉上方「方案 A」的設定
# SOUL_LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# SOUL_LLM_MODEL=claude-3-5-sonnet-20241022
# SOUL_LLM_TEMPERATURE=0.3

# 搭配 OpenAI Embedding
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# SOUL_EMBEDDING_PROVIDER=openai
# SOUL_EMBEDDING_MODEL=text-embedding-3-small
# SOUL_EMBEDDING_DIM=1536

# 👉 如果選擇此方案，請跳過下方「方案 C」


# 🟠 快速方案 C：成本最低（Google LLM + OpenAI Embedding）
# ─────────────────────────────────────────────────────────────────────
# 若使用此方案，取消以下行的註釋，並註釋掉上方「方案 A」和「方案 B」的設定
# SOUL_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# SOUL_LLM_MODEL=google/gemini-2-flash           # 免費或極低成本
# SOUL_LLM_TEMPERATURE=0.3

# OpenAI Embedding（質量最好，成本低）
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here
# SOUL_EMBEDDING_PROVIDER=openai
# SOUL_EMBEDDING_MODEL=text-embedding-3-small
# SOUL_EMBEDDING_DIM=1536


# ═══════════════════════════════════════════════════════════════════════
# 核心配置
# ═══════════════════════════════════════════════════════════════════════

# ── FalkorDB 圖譜數據庫 ──────────────────────────────────────────────
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=

# ── openSOUL 核心設定 ────────────────────────────────────────────────
# 記憶文件和工作區路徑
SOUL_WORKSPACE_PATH=./workspace

# LLM 溫度（影響回應的隨機性和創意度）
# 0.0 = 完全確定性（嚴謹、重複）
# 0.3 = 推薦值（平衡、可靠）
# 1.0 = 最大創意（隨機、發散）
SOUL_LLM_TEMPERATURE=0.3

# ── 記憶圖譜名稱 ─────────────────────────────────────────────────────
# 三層記憶對應的 FalkorDB 圖名稱（一般無需修改）
SOUL_SEMANTIC_GRAPH=soul_semantic
SOUL_EPISODIC_GRAPH=soul_episodic
SOUL_PROCEDURAL_GRAPH=soul_procedural

# ── 記憶邊權重參數 ───────────────────────────────────────────────────
# 影響記憶檢索的相關性評分計算
SOUL_WEIGHT_ALPHA=0.3      # 近期性權重（最近的記憶更重要）
SOUL_WEIGHT_BETA=0.4       # 頻率權重（經常出現的更重要）
SOUL_WEIGHT_GAMMA=0.3      # 顯著性權重（令人印象深刻的更重要）
SOUL_DECAY_LAMBDA=0.01     # 遺忘衰減率（每小時，越高遺忘越快）
SOUL_PRUNE_THRESHOLD=0.05  # 邊緣刪除閾值（低於此分數的連接會被刪除）

# ── 行為驗證（Judge Agent）────────────────────────────────────────────
SOUL_VERIFY_MAX_RETRIES=3
SOUL_VERIFY_THRESHOLD=0.6  # 基底核驗證通過分數（0.0-1.0）

# ── 夢境引擎 ──────────────────────────────────────────────────────────
# 用於定時反思和記憶回放
SOUL_DREAM_IDLE_MINUTES=120         # 無互動多久後觸發夢境（分鐘）
SOUL_DREAM_CRON=0 3 * * *           # Cron 表達式，每日凌晨 3 點
SOUL_DREAM_REPLAY_DA_THRESHOLD=0.3  # 多巴胺閾值（高於此時觸發反思）

# 夢境反思 Telegram 通知（可選，使用 OpenClaw 的 Telegram Bot）
SOUL_DREAM_TELEGRAM_NOTIFY=true     # 是否發送夢境反思到 Telegram
# 注：自動從 openclaw/.env 的 TELEGRAM_BOT_TOKEN 讀取

# ── FastAPI 服務設定 ──────────────────────────────────────────────────
SOUL_API_HOST=0.0.0.0
SOUL_API_PORT=8001
SOUL_API_RELOAD=true

# ── Gmail 郵件集成（OAuth2）───────────────────────────────────────────
# Gmail 帳號地址
GMAIL_ADDRESS=your-email@gmail.com

# OAuth2 認證文件路徑（自動生成）
# 需將 Google Cloud Console 下載的 credentials.json 放在此路徑
# GMAIL_CREDENTIALS_PATH=./workspace/credentials.json

# OAuth2 令牌文件（首次授權後自動生成）
# GMAIL_TOKEN_PATH=./workspace/token.json

# 郵件檢查間隔（分鐘）
GMAIL_CHECK_INTERVAL_MINUTES=5

# ── OpenClaw 技能庫路徑 ───────────────────────────────────────────────
OPENCLAW_SKILLS_PATH=~/.openclaw/skills
